# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Ignore all .log files
*.log

# Ignore all files in the 'build' directory
/build/

# Ignore the 'node_modules' directory often used in JavaScript projects
node_modules/

# Ignore specific files
.DS_Store
.env
config.local.js

# Ignore all files ending with .tmp
*.tmp

# Ignore all files in any directory named 'temp'
**/temp/

# Ignore the entire 'vendor' directory
vendor/

# Exception: don't ignore 'important.log' even if it's a .log file
!important.log